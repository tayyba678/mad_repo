<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingBottom="32dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#E3FAE9"
            android:layout_marginStart="-20dp"
            android:layout_marginEnd="-20dp"
            android:paddingBottom="28dp">

            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/logo"
                    android:background="@drawable/bg_avatar_circle"
                    android:scaleType="centerCrop"
                    android:padding="4dp"/>
            </FrameLayout>

            <TextView
                android:id="@+id/headerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Name"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"/>

            <TextView
                android:id="@+id/headerDept"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Department"
                android:textColor="#E8F5E9"
                android:textSize="13sp"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FFFFFF"
            android:layout_marginTop="-20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:paddingTop="28dp"
                android:paddingBottom="24dp">

                <!-- SECTION -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PERSONAL INFO"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:textColor="#AAAAAA"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="16dp"/>

                <!-- NAME -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Name"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/name"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="Enter full name"
                    android:textColor="#1A1A2E"
                    android:textColorHint="#CCCCCC"
                    android:textSize="14sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_input_white"
                    android:inputType="textPersonName"
                    android:layout_marginBottom="16dp"/>

                <!-- REG NO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Registration Number"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/regNo"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="e.g. 2021-CS-123"
                    android:textColor="#1A1A2E"
                    android:textColorHint="#CCCCCC"
                    android:textSize="14sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_input_white"
                    android:layout_marginBottom="16dp"/>

                <!-- DEPARTMENT -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Department"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="6dp"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input_white"
                    android:layout_marginBottom="16dp">

                    <Spinner
                        android:id="@+id/departmentSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"/>
                </FrameLayout>

                <!-- YEAR -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admission Year"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="6dp"/>


                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:background="@drawable/bg_input_white"
                    android:layout_marginBottom="16dp">

                    <Spinner
                        android:id="@+id/admissionYearSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"/>
                </FrameLayout>
                <!-- PHONE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone Number"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/phone"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:hint="03XXXXXXXXX"
                    android:textColor="#1A1A2E"
                    android:textColorHint="#CCCCCC"
                    android:textSize="14sp"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_input_white"
                    android:inputType="phone"
                    android:layout_marginBottom="24dp"/>

                <!-- DIVIDER -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#F0F0F0"
                    android:layout_marginBottom="24dp"/>

                <!-- BUTTON -->
                <Button
                    android:id="@+id/updateBtn"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Save Changes"
                    android:textColor="#FFFFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_green"
                    android:letterSpacing="0.04"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>