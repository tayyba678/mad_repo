<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <ImageView
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:src="@drawable/logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registration Form"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#222222"
                android:layout_marginTop="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fill your details to continue"
                android:textSize="14sp"
                android:textColor="#000000"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#eafaea"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- FULL NAME -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Name"
                    android:textSize="13sp"
                    android:textColor="#000000"/>

                <EditText
                    android:id="@+id/name"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Enter full name"
                    android:padding="14dp"
                    android:background="@drawable/bg_input_white"
                    android:layout_marginBottom="14dp"/>

                <!-- REG NO -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Registration Number"
                    android:textSize="13sp"
                    android:textColor="#000000"/>

                <EditText
                    android:id="@+id/regNo"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="e.g. 2021-CS-123"
                    android:padding="14dp"
                    android:background="@drawable/bg_input_white"
                    android:layout_marginBottom="14dp"/>

                <!-- DEPARTMENT -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Department"
                    android:textSize="13sp"
                    android:textColor="#000000"/>

                <EditText
                    android:id="@+id/department"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Computer Science"
                    android:padding="14dp"
                    android:background="@drawable/bg_input_white"
                    android:layout_marginBottom="14dp"/>

                <!-- ADMISSION YEAR -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admission Year"
                    android:textSize="13sp"
                    android:textColor="#000000"/>

                <EditText
                    android:id="@+id/admissionYear"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="2022"
                    android:inputType="number"
                    android:padding="14dp"
                    android:background="@drawable/bg_input_white"
                    android:layout_marginBottom="14dp"/>

                <!-- PHONE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone Number"
                    android:textSize="13sp"
                    android:textColor="#000000"/>

                <EditText
                    android:id="@+id/phone"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="03XXXXXXXXX"
                    android:inputType="phone"
                    android:padding="14dp"
                    android:background="@drawable/bg_input_white"
                    android:layout_marginBottom="14dp"/>

                <!-- GENDER -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gender"
                    android:textSize="13sp"
                    android:textColor="#000000"
                    android:layout_marginBottom="6dp"/>

                <RadioGroup
                    android:id="@+id/genderGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="20dp">

                    <RadioButton
                        android:id="@+id/male"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Male"/>

                    <RadioButton
                        android:id="@+id/female"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Female"
                        android:layout_marginStart="20dp"/>

                    <RadioButton
                        android:id="@+id/other"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Other"
                        android:layout_marginStart="20dp"/>
                </RadioGroup>

                <!-- BUTTON -->
                <Button
                    android:id="@+id/submitBtn"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="Continue"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_button_green"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>