<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FF"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="24dp">

            <ImageView
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:src="@drawable/logo"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Create Profile"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#1A1A2E"
                android:layout_marginTop="12dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fill in your university details"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- MAIN CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="24dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="#FAE3E7"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- FULL NAME -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full Name"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/name"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="e.g. Ahmed Raza"
                    android:textSize="13sp"
                    android:textColor="#1A1A2E"
                    android:textColorHint="#BBBBBB"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_input_white"
                    android:inputType="textPersonName"
                    android:layout_marginBottom="16dp"/>

                <!-- REGISTRATION NUMBER -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Registration Number"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/regNo"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="e.g. 2021-CS-123"
                    android:textSize="13sp"
                    android:textColor="#1A1A2E"
                    android:textColorHint="#BBBBBB"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_input_white"
                    android:inputType="text"
                    android:layout_marginBottom="16dp"/>

                <!-- DEPARTMENT -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Department"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="6dp"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_white"
                    android:layout_marginBottom="6dp">

                    <Spinner
                        android:id="@+id/departmentSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"/>
                </FrameLayout>

                <!-- Department manual input (if Other selected) -->
                <EditText
                    android:id="@+id/department"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="Type your department"
                    android:textSize="13sp"
                    android:textColor="#1A1A2E"
                    android:textColorHint="#BBBBBB"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_input_white"
                    android:visibility="gone"
                    android:layout_marginBottom="16dp"/>

                <!-- ADMISSION YEAR -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admission Year"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="6dp"/>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_white"
                    android:layout_marginBottom="16dp">

                    <Spinner
                        android:id="@+id/admissionYearSpinner"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp"/>
                </FrameLayout>

                <!-- PHONE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone Number"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="6dp"/>

                <EditText
                    android:id="@+id/phone"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:hint="03XXXXXXXXX"
                    android:textSize="13sp"
                    android:textColor="#1A1A2E"
                    android:textColorHint="#BBBBBB"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="@drawable/bg_input_white"
                    android:inputType="phone"
                    android:layout_marginBottom="16dp"/>

                <!-- GENDER -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gender"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:textColor="#555555"
                    android:layout_marginBottom="10dp"/>

                <RadioGroup
                    android:id="@+id/genderGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="24dp">

                    <RadioButton
                        android:id="@+id/male"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Male"
                        android:textSize="13sp"
                        android:textColor="#333333"/>

                    <RadioButton
                        android:id="@+id/female"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Female"
                        android:textSize="13sp"
                        android:textColor="#333333"
                        android:layout_marginStart="20dp"/>

                    <RadioButton
                        android:id="@+id/other"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Other"
                        android:textSize="13sp"
                        android:textColor="#333333"
                        android:layout_marginStart="20dp"/>

                </RadioGroup>

                <!-- SUBMIT BUTTON -->
                <Button
                    android:id="@+id/submitBtn"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Continue"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/bg_button_green"
                    android:letterSpacing="0.05"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>