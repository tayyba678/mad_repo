<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- MAIN CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="#F4F6FB">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#D6B9ED"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="48dp"
            android:paddingBottom="24dp">

            <!-- TOP ROW -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <!-- MENU BUTTON -->
                <TextView
                    android:id="@+id/menuBtn"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="☰"
                    android:textSize="22sp"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="#8A30D1"
                    android:padding="8dp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>

                <!-- COUNTER BADGE -->
                <TextView
                    android:id="@+id/selectedCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 selected"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"/>

            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Your Interests"
                android:textColor="#FFFFFF"
                android:textSize="26sp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pick what you love — we'll find your people"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- INTEREST LIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:clipToPadding="false"/>

        <!-- BOTTOM BUTTON -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="12dp"
            android:paddingBottom="20dp"
            android:elevation="8dp">

            <Button
                android:id="@+id/btnContinue"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Find My Matches →"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:background="#8A30D1"
                android:letterSpacing="0.03"/>

        </LinearLayout>

    </LinearLayout>

    <!-- SIDEBAR DRAWER -->
    <LinearLayout
        android:id="@+id/drawerMenu"
        android:layout_width="285dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="#FFFFFF">

        <!-- SIDEBAR HEADER - solid green block -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:orientation="vertical"
            android:gravity="bottom"
            android:background="#D6B9ED"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <!-- AVATAR CIRCLE -->
            <FrameLayout
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:background="@drawable/bg_avatar_circle"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="👤"
                    android:textSize="24sp"
                    android:gravity="center"/>
            </FrameLayout>

            <TextView
                android:id="@+id/profileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="UniMatch"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="17sp"/>

            <TextView
                android:id="@+id/profileDept"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="University Connect"
                android:textColor="#A5D6A7"
                android:textSize="12sp"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- MENU ITEMS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="12dp">

            <!-- PROFILE ITEM -->
            <LinearLayout
                android:id="@+id/btnProfile"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="👤"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:background="#E8F5E9"
                    android:padding="4dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="My Profile"
                    android:textSize="15sp"
                    android:textColor="#1A1A2E"
                    android:layout_marginStart="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="20sp"
                    android:textColor="#CCCCCC"/>

            </LinearLayout>

            <!-- DIVIDER -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F5F5F5"
                android:layout_marginStart="24dp"
                android:layout_marginEnd="24dp"/>

            <!-- SIGN OUT ITEM -->
            <LinearLayout
                android:id="@+id/btnLogout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:text="🚪"
                    android:textSize="18sp"
                    android:gravity="center"
                    android:background="#FFEBEE"
                    android:padding="4dp"/>

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Sign Out"
                    android:textSize="15sp"
                    android:textColor="#D32F2F"
                    android:layout_marginStart="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="20sp"
                    android:textColor="#CCCCCC"/>

            </LinearLayout>

        </LinearLayout>

        <!-- VERSION at bottom -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="bottom|center_horizontal"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UniMatch v1.0"
                android:textColor="#CCCCCC"
                android:textSize="11sp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>